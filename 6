

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns


data = pd.read_csv("cleaned_data.csv")


print(data.head())


print(data.describe())


print(data.isnull().sum())


data.hist()
plt.show()


sns.heatmap(data.corr(), annot=True)
