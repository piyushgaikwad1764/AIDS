import numpy as np
from sklearn.datasets import fetch_california_housing
from sklearn.model_selection import train_test_split, cross_val_score
from sklearn.tree import DecisionTreeRegressor
from sklearn.metrics import mean_squared_error


data = fetch_california_housing()
X, y = data.data, data.target


X_small, y_small = X[:200], y[:200]
X_large, y_large = X[:2000], y[:2000]


model_low = DecisionTreeRegressor(max_depth=2, random_state=42)

X_train_s, X_test_s, y_train_s, y_test_s = train_test_split(
    X_small, y_small, test_size=0.2, random_state=42)

model_low.fit(X_train_s, y_train_s)
pred_low = model_low.predict(X_test_s)

print("Bias Model MSE:", mean_squared_error(y_test_s, pred_low))


model_high = DecisionTreeRegressor(max_depth=None, random_state=42)

X_train_l, X_test_l, y_train_l, y_test_l = train_test_split(
    X_large, y_large, test_size=0.2, random_state=42)

model_high.fit(X_train_l, y_train_l)  # ✅ fixed
pred_high = model_high.predict(X_test_l)  # ✅ fixed

print("Variance Model MSE:", mean_squared_error(y_test_l, pred_high))


X_dup = np.vstack([X_small, X_small])
y_dup = np.hstack([y_small, y_small])

model_dup = DecisionTreeRegressor(random_state=42)
model_dup.fit(X_dup, y_dup)

pred_dup = model_dup.predict(X_test_s)

print("Duplicate Data MSE:", mean_squared_error(y_test_s, pred_dup))


cv_low = cross_val_score(model_low, X_large, y_large,
                         cv=5, scoring='neg_mean_squared_error')
print("Low Complexity CV MSE:", -cv_low.mean())

cv_high = cross_val_score(model_high, X_large, y_large,
                          cv=5, scoring='neg_mean_squared_error')
print("High Complexity CV MSE:", -cv_high.mean())
